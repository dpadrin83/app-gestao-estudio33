# =====================================================================
# Hub Estúdio 33 — variáveis de ambiente locais
# Copie este arquivo para .env.local e preencha os valores reais
# (.env.local nunca vai pro git — só este .example fica versionado)
# =====================================================================

# ---- Supabase (auth + Postgres + storage + RLS) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic (camada de IA — Fase 4) ----
ANTHROPIC_API_KEY=
# Opcional — padrão: claude-sonnet-4-20250514
ANTHROPIC_MODEL=

# ---- Briefing Studio → Hub (webhook Fase 4) ----
# Gere um token longo e use: Authorization: Bearer <token>
BRIEFING_STUDIO_SECRET=

# ---- App URL (links em e-mails e convites — obrigatório em produção) ----
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3333

# ---- Resend (e-mails: convite portal, entregável, reset senha) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=Hub Estúdio 33 <onboarding@resend.dev>
HUB_ADMIN_EMAIL=
